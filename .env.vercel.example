# ============================================================
# 갓챠사주 — Vercel 프로덕션 환경변수 템플릿 (.env.vercel)
# ============================================================
# 사용법:
#   1. 이 파일을 복사해 로컬에 `.env.vercel`로 저장 (gitignored)
#   2. 각 값을 실제 키로 채움 (출처는 docs/vercel-env-setup.md §2 참고)
#   3-A. Vercel Dashboard → Project → Settings → Environment Variables
#        → "Import .env" 버튼으로 한 번에 업로드
#   3-B. 또는 vercel CLI: `vercel env add` 로 하나씩
#   4. 환경 선택: Production / Preview / Development 모두 체크
#
# 카테고리:
#   1) Supabase (DB)        2) NextAuth.js
#   3) 공개 URL (sitemap)   4) OAuth (카카오/네이버/구글)
#   5) Google Gemini        6) Toss Payments
#   ⚠ Vercel 절대 금지: USE_MOCK_READINGS
#
# 도메인:
#   메인: https://gatch-saju.onato.co.kr
#   백업(Vercel 기본): https://{프로젝트}.vercel.app
# ============================================================


# --- 1) Supabase (DB) ---
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
# ⚠ service_role 키 — 서버 사이드만 사용. 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# --- 2) NextAuth.js ---
# 생성: openssl rand -base64 32 (로컬과 다른 값 권장)
NEXTAUTH_SECRET=
# 프로덕션 도메인 (커스텀 도메인 확정 후 갱신 + Redeploy 필요)
NEXTAUTH_URL=https://gatch-saju.onato.co.kr


# --- 3) 공개 URL (sitemap·canonical·OG·랜딩) ---
# NEXTAUTH_URL과 동일 값으로 유지
NEXT_PUBLIC_SITE_URL=https://gatch-saju.onato.co.kr


# --- 4) OAuth ---
# 각 콘솔에서 Redirect URI 등록 필수:
#   카카오: https://{도메인}/api/auth/callback/kakao
#   네이버: https://{도메인}/api/auth/callback/naver
#   구글:   https://{도메인}/api/auth/callback/google
# 백업 도메인(*.vercel.app)도 함께 등록 권장 (Preview 빌드 테스트용)

# 4-1. 카카오 — 카카오 개발자 콘솔
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 4-2. 네이버 — 출시 1차에선 UI 비활성 (등록 불필요)
# 활성화 시점에 네이버 개발자센터에서 발급 후 등록
# 발급 가이드: Obsidian "OAuth 키 발급 가이드 (네이버·구글)"
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 4-3. 구글 — 출시 1차에선 UI 비활성 (등록 불필요)
# 활성화 시점에 Google Cloud Console에서 발급 후 등록
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# --- 5) Google Gemini ---
# Google AI Studio → Create API Key
GEMINI_API_KEY=


# --- 6) Toss Payments ---
# 토스페이먼츠 개발자센터 → 내 개발 → API 키
# 라이브 키 발급 전엔 테스트 키 사용
TOSS_SECRET_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=


# ============================================================
# ⚠ Vercel에 절대 추가하면 안 되는 변수
# ============================================================
# USE_MOCK_READINGS=...
#   — 프로덕션에서 실결제 시 mock 데이터 반환 참사 방지.
#   코드(generate-reading.ts)에 NODE_ENV production 시 강제 false
#   가드가 있으나 이중 방어를 위해 env에도 넣지 않는다.

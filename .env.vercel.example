# ============================================================
# 갓챠사주 — Vercel 환경변수 템플릿
# ============================================================
# 사용법:
#   1. 이 파일을 복사해 로컬에 `.env.vercel`로 저장
#   2. 각 값을 실제 키로 채움 (출처는 docs/vercel-env-setup.md 참고)
#   3-A. Vercel Dashboard → Project → Settings → Environment Variables
#        → "Import .env" 버튼 → 저장한 파일 업로드 or 내용 붙여넣기
#   3-B. 또는 vercel CLI: `vercel env add` 로 하나씩
# ============================================================

# --- Supabase (DB) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- NextAuth.js ---
# NEXTAUTH_SECRET은 `openssl rand -base64 32` 로 생성
NEXTAUTH_SECRET=
# 프로덕션 도메인 (예: https://gatch-saju.vercel.app 또는 커스텀 도메인)
NEXTAUTH_URL=https://gatch-saju.vercel.app

# --- 공개 URL (sitemap·canonical·OG·랜딩 등에서 사용) ---
NEXT_PUBLIC_SITE_URL=https://gatch-saju.vercel.app

# --- OAuth: 카카오 (유일하게 활성화된 공급자) ---
# 카카오 개발자 콘솔 → 내 애플리케이션 → 앱 설정
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# Redirect URI에 반드시 추가:
#   https://{배포도메인}/api/auth/callback/kakao

# --- Google Gemini ---
GEMINI_API_KEY=

# --- Toss Payments ---
# 개발자센터 → 내 개발 → API 키
TOSS_SECRET_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# ============================================================
# ⚠ Vercel에 절대 추가하면 안 되는 변수
# ============================================================
# USE_MOCK_READINGS=...
#   — 프로덕션에서 실결제 시 mock 데이터 반환 참사 방지.
#   코드(generate-reading.ts)에 NODE_ENV production 시 강제 false
#   safeguard가 있으나 이중 방어를 위해 env에도 넣지 않는다.

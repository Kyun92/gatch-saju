# ============================================================
# 갓챠사주 — 로컬 개발 환경변수 템플릿 (.env.local)
# ============================================================
# 사용법:
#   1. 이 파일을 복사해 `.env.local`로 저장 (gitignored)
#   2. 각 값을 실제 키로 채움 (출처는 docs/vercel-env-setup.md §2 참고)
#
# 카테고리:
#   1) Supabase (DB)        2) NextAuth.js
#   3) 공개 URL (sitemap)   4) OAuth (카카오/네이버/구글)
#   5) Google Gemini        6) Toss Payments
#   7) Dev Only (USE_MOCK_READINGS — 로컬 한정)
# ============================================================


# --- 1) Supabase (DB) ---
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# ⚠ service_role 키 — 서버 사이드만 사용. 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=


# --- 2) NextAuth.js ---
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=
# 로컬 dev URL
NEXTAUTH_URL=http://localhost:3000


# --- 3) 공개 URL (sitemap·canonical·OG·랜딩) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# --- 4) OAuth ---
# 4-1. 카카오 — 카카오 개발자 콘솔
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 4-2. 네이버 — 출시 1차에선 UI 비활성 (로컬 테스트도 카카오만 사용)
# 활성화 시점에 발급 후 채움. 발급 가이드: Obsidian "OAuth 키 발급 가이드 (네이버·구글)"
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 4-3. 구글 — 출시 1차에선 UI 비활성
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# --- 5) Google Gemini ---
# Google AI Studio → Create API Key
GEMINI_API_KEY=


# --- 6) Toss Payments ---
# 토스페이먼츠 개발자센터 → 내 개발 → API 키
# 라이브 키 발급 전엔 테스트 키 사용 가능
TOSS_SECRET_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=


# --- 7) Dev Only ---
# ⚠ 프로덕션 환경(Vercel)에는 절대 등록 금지
# true: Gemini API 호출 없이 mock 데이터로 감정 생성 (로컬 테스트용)
# 코드(generate-reading.ts)에 NODE_ENV production 시 강제 false 가드 있음
USE_MOCK_READINGS=true
